# Frontend Configuration - Only PUBLIC variables (prefix with NEXT_PUBLIC_)
# These variables are embedded in the frontend bundle and visible to browsers

# API Backend URL - where the frontend sends requests
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Google OAuth Client ID (Public - safe to expose)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# ⚠️ IMPORTANT: DO NOT add backend-only variables here:
# ❌ DO NOT add BETTER_AUTH_SECRET (backend only)
# ❌ DO NOT add MONGODB_URI (backend only)
# ❌ DO NOT add GOOGLE_CLIENT_SECRET (backend only)
# ❌ DO NOT add any private API keys or credentials

# Backend-only configuration is in server/.env
# Never commit any .env files to git - they contain sensitive data
